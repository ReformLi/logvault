# NextAuth v5 必需 (二选一)
AUTH_SECRET=openssl rand -base64 32

# GitHub OAuth (二选一，推荐 AUTH_ 前缀)
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# 允许登录的邮箱 (逗号分隔)
ALLOWED_EMAILS=your@email.com

# 管理员邮箱 (逗号分隔，拥有设置/删除/审计日志权限)
# ADMIN_EMAILS=admin@email.com

# Vercel 项目 (VERCEL_TOKEN 必需)
VERCEL_TOKEN=your_vercel_api_token
VERCEL_PROJECT_NAME=your_project_name
# VERCEL_PROJECT_ID=your_project_id

# Vercel 团队/用户 ID (GitHub Actions 必需配置，应用代码可自动检测)
# VERCEL_OWNER_ID=your_team_or_user_id

# CRON 鉴权 (保护 /api/fetch/cron, /api/cleanup, /api/logs/store 接口)
# CRON_SECRET=openssl rand -hex 32

# 加密密钥 (必需，AES-256-GCM)
ENCRYPTION_SECRET=any_random_secret_string_at_least_32_chars

# 本地模式开关 (true=pg 直连本地数据库, 缺省或 false=@vercel/postgres)
USE_LOCAL_DB=true

# 本地 PostgreSQL 连接 (仅 USE_LOCAL_DB=true 时生效)
POSTGRES_URL=postgresql://postgres:password@localhost:5432/logvault_local
